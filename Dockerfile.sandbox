FROM python:3.12-slim

RUN pip install --no-cache-dir fastapi uvicorn python-multipart pymupdf python-docx pandas openpyxl

ENV UPLOAD_PATH=/sandbox_files
RUN mkdir -p /sandbox_files

COPY src/utils/executor_server.py /executor_server.py

RUN adduser --disabled-password --no-create-home sandbox \
    && chown sandbox:sandbox /sandbox_files /tmp

USER sandbox

CMD ["python", "/executor_server.py"]